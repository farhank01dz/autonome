# Autonome environment template
# Copy to .env and replace placeholders. Never commit real secrets.

# -------------------------------------------------------------------
# Server & Database
# -------------------------------------------------------------------
SERVER_URL=https://localhost:3000
DATABASE_URL=postgres://user:password@localhost:5432/autonome
TRADING_MODE=simulated
IS_SIMULATION_ENABLED=true

# -------------------------------------------------------------------
# Lighter API
# -------------------------------------------------------------------
LIGHTER_API_KEY_INDEX=2
LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai

# -------------------------------------------------------------------
# Simulator Tuning
# -------------------------------------------------------------------
SIM_INITIAL_CAPITAL=10000
SIM_QUOTE_CURRENCY=USDT
SIM_REFRESH_INTERVAL_MS=3000

# -------------------------------------------------------------------
# AI Providers & Tooling
# -------------------------------------------------------------------
MISTRAL_API_KEY=
NIM_API_KEY=
OPENROUTER_API_KEY=

# -------------------------------------------------------------------
# Client-facing values (must start with VITE_)
# -------------------------------------------------------------------
VITE_SENTRY_DSN=
VITE_APP_TITLE=Autonome
