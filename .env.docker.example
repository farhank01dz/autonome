# Autonome Docker Environment Configuration
# Copy this file to .env.docker and fill in your values
# Usage: docker compose --env-file .env.docker up -d

# -------------------------------------------------------------------
# Database Configuration (NeonDB)
# -------------------------------------------------------------------
# Get your connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/autonome?sslmode=require

# -------------------------------------------------------------------
# Server Configuration
# -------------------------------------------------------------------
SERVER_URL=http://localhost:3000

# -------------------------------------------------------------------
# Lighter API Configuration
# -------------------------------------------------------------------
LIGHTER_API_KEY_INDEX=2
LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai

# -------------------------------------------------------------------
# Trading Configuration
# -------------------------------------------------------------------
TRADING_MODE=simulated

# -------------------------------------------------------------------
# Simulator Configuration
# -------------------------------------------------------------------
SIM_INITIAL_CAPITAL=10000
SIM_QUOTE_CURRENCY=USDT
SIM_REFRESH_INTERVAL_MS=30000

# -------------------------------------------------------------------
# AI Provider API Keys (Required)
# -------------------------------------------------------------------
NIM_API_KEY=your_nim_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
MISTRAL_API_KEY=your_mistral_api_key

# -------------------------------------------------------------------
# Client Configuration
# -------------------------------------------------------------------
VITE_APP_TITLE=Autonome
